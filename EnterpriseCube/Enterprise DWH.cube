  <MdxScripts>
    <MdxScript dwd:design-time-name="ea99fc36-33fc-4e97-a7f1-08b005a3f284">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;  
CREATE MEMBER CURRENTCUBE.[Measures].[Total Spend]
 AS SUM([Measures].[Total Amount]), 
FORMAT_STRING = "Standard", 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Total Orders]
 AS [Measures].[Fact Purchases Count], 
FORMAT_STRING = "Standard", 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Total Quantity Ordered]
 AS [Measures].[Ordered Quantity], 
FORMAT_STRING = "Standard", 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Total Quantity Received]
 AS [Measures].[Received Quantity], 
FORMAT_STRING = "Standard", 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Fill Rate]
 AS IIF(
 [Measures].[Ordered Quantity]=0,
 NULL,
 [Measures].[Received Quantity]
 /
 [Measures].[Ordered Quantity]
), 
FORMAT_STRING = "Percent", 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Average Order Value]
 AS IIF(
    [Measures].[Fact Purchases Count] = 0,
    NULL,
    [Measures].[Total Amount]
    /
    [Measures].[Fact Purchases Count]
), 
FORMAT_STRING = "Standard", 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>